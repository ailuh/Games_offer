# Copy this file to .env and fill in real values. Never commit .env.

# --- core ---
NODE_ENV=development
API_PORT=3000
# Public origin of the web app (used for CORS and cookie domain)
WEB_ORIGIN=http://localhost:5173
# Domain Caddy serves in production (leave as localhost for local Docker)
DOMAIN=localhost
# Long random string for signing session cookies
SESSION_SECRET=change_me_to_a_long_random_string

# --- database ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me
POSTGRES_DB=app
# Inside Docker the host is the service name "postgres"; locally use "localhost"
DATABASE_URL=postgresql://app:change_me@localhost:5432/app

# --- telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=
# Bot username without @, used by the website login widget
TELEGRAM_BOT_USERNAME=
# Comma-separated numeric Telegram user ids allowed to use the app and bot.
# These users send games/links directly to the bot in any format; it classifies
# and parses each message into the games or videos pool. Release notifications are
# sent directly to each of these users.
ALLOWED_TELEGRAM_IDS=

# --- openai ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Application-enforced cap; OpenAI's own budget limit only notifies, it does not stop spend
OPENAI_DAILY_TOKEN_CAP=200000

# --- optional ---
TZ=Europe/Moscow
