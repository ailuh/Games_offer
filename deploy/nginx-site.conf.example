# Host nginx vhost for serving the app behind an existing nginx, paired with
# docker-compose.behind-proxy.yml (web on 127.0.0.1:8090, api on 127.0.0.1:3090).
#
# Usage:
#   1. Replace your-domain.example below with your real domain.
#   2. sudo cp deploy/nginx-site.conf.example /etc/nginx/sites-available/watchlist-hub
#   3. sudo ln -s /etc/nginx/sites-available/watchlist-hub /etc/nginx/sites-enabled/
#   4. sudo nginx -t && sudo systemctl reload nginx
#   5. sudo certbot --nginx -d your-domain.example
#      certbot adds the TLS (443) server block and the 80->443 redirect for you.
#
# The X-Forwarded-Proto header is required: the api trusts the proxy and only
# sets its secure session cookie when it sees the request arrived over HTTPS.

server {
    listen 80;
    server_name your-domain.example;

    location /api/ {
        proxy_pass http://127.0.0.1:3090;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Socket.IO needs the WebSocket upgrade headers.
    location /socket.io/ {
        proxy_pass http://127.0.0.1:3090;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:8090;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
